# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...    # Settings → API → service_role (NOT anon key)

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_PAT=ghp_...                   # Settings → Developer settings → Personal access tokens
                                     # Scopes needed: repo (full), workflow
GITHUB_ORG_OR_USER=anthonynjenga2020
GITHUB_TEMPLATE_REPO=jenga-gym-template

# ─── Vercel ───────────────────────────────────────────────────────────────────
VERCEL_TOKEN=...                     # vercel.com → Settings → Tokens
VERCEL_TEAM_ID=                      # Leave blank if personal account

# ─── Paystack (used by config-builder for client sites) ──────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_...

# ─── Outreach / Demo ─────────────────────────────────────────────────────────
DEMO_BASE_URL=https://demo.jengasystems.online

# ─── Google Maps Scraper ─────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
